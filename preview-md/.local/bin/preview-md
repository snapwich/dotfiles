#!/usr/bin/env node

// serve-md: Serves markdown files as HTML with Mermaid diagram support.
// Usage: node serve-md.mjs [dir] [--port=3000]
//
// Browse to http://localhost:3000/ for a file listing,
// or http://localhost:3000/path/to/file.md for rendered output.

import { createServer } from "node:http";
import { readFile, readdir, stat } from "node:fs/promises";
import { join, extname, relative, resolve } from "node:path";

const args = process.argv.slice(2);
const portArg = args.find((a) => a.startsWith("--port="));
const port = portArg ? Number(portArg.split("=")[1]) : 3000;
const root = resolve(args.find((a) => !a.startsWith("--")) || ".");

// We load markdown-it from CDN at runtime in the browser to avoid npm deps.
// Mermaid is also loaded from CDN. Zero dependencies.

const HTML_TEMPLATE = (title, body) => `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>${title}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css@5/github-markdown-light.min.css">
<style>
  body { max-width: 1400px; margin: 0 auto; padding: 2rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; }
  .markdown-body { box-sizing: border-box; min-width: 200px; max-width: 1400px; }
  .mermaid { text-align: center; }
  pre:has(> code.language-mermaid) { background: none; border: none; padding: 0; }
  a { text-decoration: none; }
  a:hover { text-decoration: underline; }
  .file-list { list-style: none; padding: 0; }
  .file-list li { padding: 0.3rem 0; }
  .file-list li::before { content: "📄 "; }
  .file-list li.dir::before { content: "📁 "; }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/styles/github.min.css">
</head>
<body class="markdown-body">
${body}
<script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/highlight.min.js"></script>
<script type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
mermaid.initialize({ startOnLoad: false, theme: 'default' });

// Convert mermaid code blocks into rendered diagrams
document.querySelectorAll('code.language-mermaid').forEach((block, i) => {
  const pre = block.parentElement;
  const div = document.createElement('div');
  div.className = 'mermaid';
  div.textContent = block.textContent;
  pre.replaceWith(div);
});

document.querySelectorAll('pre code[class^="language-"]').forEach(el => hljs.highlightElement(el));

await mermaid.run({ querySelector: '.mermaid' });

// Mermaid scales SVGs to fit the container, which can shrink text
// below readability. Enlarge diagrams where text would be too small.
const MIN_FONT_PX = 10;
document.querySelectorAll('.mermaid svg').forEach(svg => {
  const vb = svg.getAttribute('viewBox');
  if (!vb) return;
  const vbWidth = parseFloat(vb.split(' ')[2]);
  const container = svg.parentElement.clientWidth;
  const textEl = svg.querySelector('text, span');
  if (!textEl) return;
  const svgFontSize = parseFloat(getComputedStyle(textEl).fontSize);
  const renderedFontSize = svgFontSize * container / vbWidth;
  if (renderedFontSize < MIN_FONT_PX) {
    const needed = Math.ceil(MIN_FONT_PX * vbWidth / svgFontSize);
    svg.style.width = needed + 'px';
    svg.style.maxWidth = 'none';
  }
});
</script>
</body>
</html>`;

async function listDir(dirPath, urlPath) {
  const entries = await readdir(dirPath, { withFileTypes: true });
  const items = entries
    .filter((e) => !e.name.startsWith("."))
    .sort((a, b) => {
      if (a.isDirectory() !== b.isDirectory()) return a.isDirectory() ? -1 : 1;
      return a.name.localeCompare(b.name);
    })
    .map((e) => {
      const href = urlPath === "/" ? `/${e.name}` : `${urlPath}/${e.name}`;
      const cls = e.isDirectory() ? ' class="dir"' : "";
      const suffix = e.isDirectory() ? "/" : "";
      return `<li${cls}><a href="${href}${suffix}">${e.name}${suffix}</a></li>`;
    })
    .join("\n");

  return HTML_TEMPLATE(
    `Index of ${urlPath}`,
    `<h1>Index of ${urlPath}</h1><ul class="file-list">${items}</ul>`,
  );
}

async function renderMarkdown(filePath) {
  const raw = await readFile(filePath, "utf-8");
  // Server-side: use a dead-simple regex-based markdown→HTML conversion.
  // It doesn't need to be perfect — we lean on github-markdown-css for styling
  // and Mermaid's client-side JS for diagrams.
  const html = simpleMarkdown(raw);
  const name = relative(root, filePath);
  return HTML_TEMPLATE(name, html);
}

// Minimal markdown-to-HTML (good enough for review; not a full spec impl)
function simpleMarkdown(src) {
  let html = src;

  // Fenced code blocks (``` ... ```)
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) => {
    const cls = lang ? ` class="language-${lang}"` : "";
    const escaped = escapeHtml(code.trimEnd());
    return `<pre><code${cls}>${escaped}</code></pre>`;
  });

  // Inline code
  html = html.replace(/`([^`]+)`/g, "<code>$1</code>");

  // Headings
  html = html.replace(/^######\s+(.*)$/gm, "<h6>$1</h6>");
  html = html.replace(/^#####\s+(.*)$/gm, "<h5>$1</h5>");
  html = html.replace(/^####\s+(.*)$/gm, "<h4>$1</h4>");
  html = html.replace(/^###\s+(.*)$/gm, "<h3>$1</h3>");
  html = html.replace(/^##\s+(.*)$/gm, "<h2>$1</h2>");
  html = html.replace(/^#\s+(.*)$/gm, "<h1>$1</h1>");

  // Horizontal rule
  html = html.replace(/^---+$/gm, "<hr>");

  // Bold / italic
  html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
  html = html.replace(/\*(.+?)\*/g, "<em>$1</em>");

  // Images
  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img alt="$1" src="$2">');

  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');

  // Blockquotes
  html = html.replace(/^>\s+(.*)$/gm, "<blockquote>$1</blockquote>");

  // Unordered lists (simple single-level)
  html = html.replace(
    /(^[-*]\s+.+\n?)+/gm,
    (match) =>
      "<ul>" + match.replace(/^[-*]\s+(.+)$/gm, "<li>$1</li>") + "</ul>",
  );

  // Paragraphs: wrap remaining bare lines, but protect <pre> blocks
  const parts = html.split(/(<pre>[\s\S]*?<\/pre>)/g);
  html = parts
    .map((part, i) => {
      if (i % 2 === 1) return part; // pre block, leave alone
      return part.replace(/^(?!<[a-z/])((?:.(?!<[a-z/]))*.)$/gm, (_, line) =>
        line && line.trim() ? `<p>${line}</p>` : "",
      );
    })
    .join("");

  // Collapse multiple blank lines
  html = html.replace(/(<\/[a-z]+>)\n{2,}/g, "$1\n");

  return html;
}

function escapeHtml(s) {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

const server = createServer(async (req, res) => {
  try {
    const urlPath = decodeURIComponent(req.url.split("?")[0]);
    const fsPath = join(root, urlPath);

    let info;
    try {
      info = await stat(fsPath);
    } catch {
      res.writeHead(404, { "Content-Type": "text/plain" });
      return res.end("Not found");
    }

    if (info.isDirectory()) {
      // If directory has index.md, render it; otherwise list files
      try {
        await stat(join(fsPath, "index.md"));
        const html = await renderMarkdown(join(fsPath, "index.md"));
        res.writeHead(200, { "Content-Type": "text/html" });
        return res.end(html);
      } catch {
        const html = await listDir(fsPath, urlPath.replace(/\/$/, "") || "/");
        res.writeHead(200, { "Content-Type": "text/html" });
        return res.end(html);
      }
    }

    if (extname(fsPath) === ".md") {
      const html = await renderMarkdown(fsPath);
      res.writeHead(200, {
        "Content-Type": "text/html; charset=utf-8",
        "Content-Disposition": "inline",
      });
      return res.end(html);
    }

    // Serve other files raw (images, etc.)
    const data = await readFile(fsPath);
    const types = {
      ".html": "text/html",
      ".css": "text/css",
      ".js": "application/javascript",
      ".png": "image/png",
      ".jpg": "image/jpeg",
      ".svg": "image/svg+xml",
      ".gif": "image/gif",
      ".json": "application/json",
    };
    res.writeHead(200, {
      "Content-Type": types[extname(fsPath)] || "application/octet-stream",
    });
    res.end(data);
  } catch (err) {
    console.error(err);
    res.writeHead(500, { "Content-Type": "text/plain" });
    res.end("Internal server error");
  }
});

server.listen(port, () => {
  console.log(`\n  serve-md  →  http://localhost:${port}/`);
  console.log(`  Serving:     ${root}`);
  console.log(`  Mermaid:     ✓ (client-side via CDN)\n`);
});
